<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="repository.fentastic" name="FENtastic Community Repository" version="1.0.0"
    provider-name="FENtastic Community">
    <extension point="xbmc.addon.repository" name="FENtastic Community Repository">
